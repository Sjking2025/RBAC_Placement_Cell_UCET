# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/placement_cell?schema=public"

# JWT Configuration
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRES_IN=7d

# Email Configuration (development — use Mailtrap or similar)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@placementcell.com
EMAIL_FROM_NAME=Placement Cell

# Client URL (Frontend)
CLIENT_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Google OAuth / Firebase
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
FIREBASE_PROJECT_NUMBER=your-firebase-project-number
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

# Password Reset Token Expiry (in minutes)
RESET_TOKEN_EXPIRE=30
